{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "skipLibCheck": true,
    "paths": {

    
    "#errors/*": ["./errors/*"],
    "#config/*": ["./config/*"],
    "#core/*": ["./core/*"],
    "#web/*": ["./web/*"],

    "#root/*": ["./*"],
    }
  },
  
  "include": ["**/*.ts", ".env"],
  "exclude": ["node_modules", "dist"]
}